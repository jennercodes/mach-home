# ─────────────────────────────────────────────────────────────────────────────
# MACH HOME — production env for docker-compose / Coolify.
# Copy to `.env` (gitignored) and fill in. On Coolify, set these in the panel.
# Generate secrets with:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (compose service) ───────────────────────────────────────────────
POSTGRES_USER=medusa
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=medusa

# ── Backend secrets — MUST be rotated away from the dev "supersecret" ─────────
JWT_SECRET=CHANGE_ME_openssl_rand_base64_32
COOKIE_SECRET=CHANGE_ME_openssl_rand_base64_32

# Postgres SSL: leave unset/false for self-hosted (compose) Postgres.
# Set to true only for managed DBs that require SSL (Neon, RDS, Supabase…).
DATABASE_SSL=false

# Admin session cookie Secure flag. Set to true in production (admin served over
# HTTPS behind a TLS proxy). Leave false for plain-HTTP local testing, or the
# admin login silently fails (cookie never set).
COOKIE_SECURE=true

# ── CORS — comma-separated, use your real production domains ──────────────────
# storefront domain(s):
STORE_CORS=https://mach-home.com,https://www.mach-home.com
# admin is served from the backend domain itself:
ADMIN_CORS=https://api.mach-home.com
# auth needs both storefront and admin origins:
AUTH_CORS=https://mach-home.com,https://www.mach-home.com,https://api.mach-home.com

# ── Cloudflare R2 (S3-compatible) — reuse the current bucket; images persist ──
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=machhome-imagenes
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_FILE_URL=https://bucket.mach-home.com

# ── Storefront ────────────────────────────────────────────────────────────────
# Server-side (SSR) backend URL — internal docker service. Rarely needs changing.
MEDUSA_BACKEND_URL=http://backend:9000

# ── Storefront BUILD ARGS (inlined into the BROWSER bundle at build time) ─────
# PUBLIC backend URL reachable by browsers (a rebuild is needed to change it).
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.mach-home.com
# Keep the existing key if you restore the current DB (pg_dump) — it stays valid.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_DEFAULT_REGION=pe
NEXT_PUBLIC_BASE_URL=https://mach-home.com
NEXT_PUBLIC_STRIPE_KEY=
